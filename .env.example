# =============================================================================
# TrailMe — environment variables (EXAMPLE)
# -----------------------------------------------------------------------------
# Copy this file to `.env` and fill in real values. NEVER commit `.env`.
# Each app reads only the vars in its section. Public (NEXT_PUBLIC_* /
# EXPO_PUBLIC_*) vars are bundled into client code — keep secrets server-only.
# =============================================================================

# -----------------------------------------------------------------------------
# Dashboard (Next.js) — apps/dashboard
# -----------------------------------------------------------------------------
# Supabase project URL, e.g. https://abcdefgh.supabase.co
NEXT_PUBLIC_SUPABASE_URL=
# Supabase anon/public key (safe to expose to the browser; RLS enforces access)
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Supabase service-role key — SERVER ONLY. Bypasses RLS. Never expose to client.
SUPABASE_SERVICE_ROLE_KEY=
# Mapbox public access token (pk.*) for rendering maps in the dashboard
NEXT_PUBLIC_MAPBOX_TOKEN=

# -----------------------------------------------------------------------------
# Mobile (Expo) — apps/mobile
# -----------------------------------------------------------------------------
# Same Supabase project URL as the dashboard
EXPO_PUBLIC_SUPABASE_URL=
# Supabase anon/public key (RLS enforces access)
EXPO_PUBLIC_SUPABASE_ANON_KEY=
# Mapbox public access token (pk.*) for rendering maps in the app
EXPO_PUBLIC_MAPBOX_TOKEN=

# -----------------------------------------------------------------------------
# Native build secrets — apps/mobile (build-time only, not bundled at runtime)
# -----------------------------------------------------------------------------
# Mapbox secret downloads token (sk.*) with DOWNLOADS:READ scope, required for
# the @rnmapbox/maps native SDK download during the EAS / native build.
MAPBOX_DOWNLOADS_TOKEN=
# transistorsoft react-native-background-geolocation license key.
# PAID dependency — required at M2 for production background tracking.
# Leave blank for M0/M1 scaffolding. See docs/SETUP.md.
RN_BG_GEO_LICENSE=

# -----------------------------------------------------------------------------
# Supabase Edge Functions — supabase/functions/*
# -----------------------------------------------------------------------------
# These are configured as Edge Function secrets (supabase secrets set ...),
# not loaded by the apps. Listed here for completeness.
# Supabase project URL (server-side name; no NEXT_PUBLIC/EXPO_PUBLIC prefix)
SUPABASE_URL=
# Service-role key for privileged writes from Edge Functions
# SUPABASE_SERVICE_ROLE_KEY  (same value as above; set as a function secret)
# HMAC secret used to sign/verify short-lived device tokens for the mobile app
DEVICE_TOKEN_SECRET=
