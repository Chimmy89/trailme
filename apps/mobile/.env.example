# Copy to .env. Runtime values (EXPO_PUBLIC_*) are inlined into the JS bundle.
# Native build secrets (MAPBOX_DOWNLOADS_TOKEN, RN_BG_GEO_LICENSE) are read at
# prebuild/EAS-build time — keep them in EAS Secrets, NOT committed.

# ── Runtime (public) ─────────────────────────────────────────────────────────
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=
EXPO_PUBLIC_MAPBOX_TOKEN=

# ── Native build secrets ─────────────────────────────────────────────────────
# Private Mapbox SDK download token (sk.* with DOWNLOADS:READ scope).
MAPBOX_DOWNLOADS_TOKEN=
# transistorsoft license — PAID, required at M2. Empty is OK for dev builds
# (logs an invalid-license warning); release builds enforce it.
RN_BG_GEO_LICENSE=
