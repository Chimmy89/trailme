{
  "name": "@trailme/mobile",
  "version": "0.0.0",
  "private": true,
  "description": "TrailMe field-guard app — Expo (SDK 52) dev-client with background GPS and native Mapbox. NOT Expo Go compatible.",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start --dev-client",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "prebuild": "expo prebuild --clean",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "1.23.1",
    "@rnmapbox/maps": "^10.1.33",
    "@supabase/supabase-js": "^2.45.4",
    "@trailme/db-types": "workspace:*",
    "@trailme/map-style": "workspace:*",
    "@trailme/shared": "workspace:*",
    "@trailme/supabase-client": "workspace:*",
    "expo": "~52.0.0",
    "expo-constants": "~17.0.3",
    "expo-linking": "~7.0.3",
    "expo-router": "~4.0.9",
    "expo-status-bar": "~2.0.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-native": "0.76.5",
    "react-native-background-geolocation": "^4.18.0",
    "react-native-gesture-handler": "~2.20.2",
    "react-native-reanimated": "~3.16.1",
    "react-native-safe-area-context": "4.12.0",
    "react-native-screens": "~4.1.0",
    "react-native-url-polyfill": "^2.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/react": "~18.3.12",
    "typescript": "^5.5.4"
  }
}
