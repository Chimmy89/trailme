{
  "name": "trailme",
  "version": "0.0.0",
  "private": true,
  "description": "TrailMe — live guard tracking, fading trails, and coverage heatmaps for field inspections.",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,yaml,yml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,yaml,yml}\""
  },
  "devDependencies": {
    "prettier": "^3.3.3",
    "supabase": "^2.107.0",
    "turbo": "^2.1.0",
    "typescript": "^5.5.4"
  }
}
